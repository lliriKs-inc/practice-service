POSTGRES_USER=practice_app
POSTGRES_PASSWORD=replace_with_url_safe_database_password
POSTGRES_DB=practice_production
DATABASE_URL=postgresql://practice_app:replace_with_url_safe_database_password@postgres:5432/practice_production?schema=public

JWT_SECRET=replace_with_at_least_32_random_characters
JWT_ISSUER=practice-service
JWT_AUDIENCE=practice-service-api

CORS_ORIGIN=https://practice.example.com
NEXT_PUBLIC_API_URL=https://api.practice.example.com/api/v1
BACKEND_PORT=3001
FRONTEND_PORT=3000
TRUST_PROXY_HOPS=1

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX_REQUESTS=30
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
JSON_BODY_LIMIT=1mb
LOG_LEVEL=info

MAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=practice@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=practice@example.com
