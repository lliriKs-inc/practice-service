# Подключение к базе данных (Формат для Prisma ORM)
# Пример для PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/cohort_db?schema=public"

# Безопасность и авторизация
# Сгенерируйте надежную случайную строку для production окружения
JWT_SECRET="your_ultra_secure_secret_key_change_me_in_production"

# Хранилище загруженных файлов
# Относительный путь считается от папки backend при локальном запуске
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# Runtime
NODE_ENV=development
PORT=3000

# JWT verification
JWT_ISSUER=practice-service
JWT_AUDIENCE=practice-service-api

# HTTP
CORS_ORIGIN=http://localhost:3001
JSON_BODY_LIMIT=1mb
